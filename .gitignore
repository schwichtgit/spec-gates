# OS and editor droppings
.DS_Store
Thumbs.db
*.swp
*~

node_modules/
*.log
/tmp/

# Local runtime-version marker written by /speckit.gates.init in real
# projects; in this repo the runtime runs from source.
.specify/gates/.runtime-version

# Claude Mind local memory store (session artifact, not project content)
.claude/mind.mv2
.claude/mind.mv2.lock

# Projected gate runtime: materialized from extension/runtime/ by CI (and by
# /speckit.gates.init in real projects). Only .specify/gates/policy.json is
# committed; the runtime copies are build artifacts.
.specify/gates/verify.sh
.specify/gates/doctor.sh
.specify/gates/canary.sh
.specify/gates/lib/
.specify/gates/policy.schema.json

# Gate run evidence (attestation log): disposable local artifact, never source.
.specify/gates/attestations.jsonl
