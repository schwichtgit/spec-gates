{
  "_comment": "spec-gates dogfoods its own enforcement. The runtime (verify.sh + lib/) is projected from runtime/ by CI and is gitignored; only this policy is committed. Excludes .specify/** so the gate does not lint its own projected copies.",
  "hooks": {
    "prettier": {
      "include": ["**/*.md", "**/*.yml", "**/*.yaml", "**/*.json"],
      "exclude": [".specify/**", "node_modules/**", "package-lock.json"],
      "orchestrator": "none",
      "severity": "error"
    },
    "markdownlint": {
      "include": ["**/*.md"],
      "exclude": [".specify/**", "node_modules/**"],
      "orchestrator": "none",
      "severity": "error"
    },
    "shellcheck": {
      "include": ["**/*.sh"],
      "exclude": [".specify/**", "node_modules/**"],
      "orchestrator": "none",
      "severity": "error"
    },
    "verify-quality": {
      "orchestrator": "none",
      "severity": "error"
    }
  }
}
