{
  "_comment": "spec-gates dogfoods its own enforcement. The runtime (verify.sh + lib/) is projected from runtime/ by CI and is gitignored; only this policy is committed. Excludes .specify/** so the gate does not lint its own projected copies. node_modules/.venv are excluded at both top-level (name/**) and any nested depth (**/name/**).",
  "attestation": {
    "parity": "error"
  },
  "hooks": {
    "markdownlint": {
      "exclude": [
        ".specify/**",
        "node_modules/**",
        "**/node_modules/**",
        ".venv/**",
        "**/.venv/**",
        ".claude/**"
      ],
      "include": [
        "**/*.md"
      ],
      "orchestrator": "none",
      "severity": "error"
    },
    "prettier": {
      "exclude": [
        ".specify/**",
        "node_modules/**",
        "**/node_modules/**",
        ".venv/**",
        "**/.venv/**",
        "package-lock.json",
        ".claude/**"
      ],
      "include": [
        "**/*.md",
        "**/*.yml",
        "**/*.yaml",
        "**/*.json"
      ],
      "orchestrator": "none",
      "severity": "error"
    },
    "shellcheck": {
      "exclude": [
        ".specify/**",
        "node_modules/**",
        "**/node_modules/**",
        ".venv/**",
        "**/.venv/**",
        ".claude/**"
      ],
      "include": [
        "**/*.sh"
      ],
      "orchestrator": "none",
      "severity": "error"
    },
    "verify-quality": {
      "orchestrator": "none",
      "severity": "error"
    }
  },
  "spec": {
    "severity": "error"
  }
}
